{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "FileUpload": {
    "StorageRootPath": "/home/data"
  },
  "Serilog": {
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "/home/logs/lms-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 60,
          "fileSizeLimitBytes": 10000000,
          "rollOnFileSizeLimit": true
        }
      }
    ]
  }
}